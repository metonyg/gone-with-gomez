# ── Local Development Environment ──────────────────────────────
# Copy this file to .env and fill in your keys.
# NEVER commit .env to GitHub — it's in .gitignore.

# Your Anthropic API key — get it at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Google Cloud (images + optional narration)
# Same service account can power Vertex AI Imagen and Cloud Text-to-Speech.
# In GCP: enable "Vertex AI API" and "Cloud Text-to-Speech API"; grant roles
# "Vertex AI User" (roles/aiplatform.user) and "Cloud Text-to-Speech User".
#
# Project ID (required for Imagen; also used if not embedded in the key JSON)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
#
# Local: point to the downloaded service account JSON key file.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account.json
#
# Alternative local/CI: paste the entire JSON key as a single line (CI uses the
# GOOGLE_SERVICE_ACCOUNT_JSON repository secret the same way).
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
#
# Override Vertex region if needed (default: us-central1)
# GOOGLE_CLOUD_LOCATION=us-central1
#
# Override Imagen model (default: imagen-3.0-generate-002)
# GOOGLE_IMAGEN_MODEL=imagen-3.0-generate-002
#
# Optional TTS voice (see cloud.google.com/text-to-speech/docs/voices); default in code.
# GOOGLE_TTS_VOICE=en-US-Neural2-F
