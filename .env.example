# ── Local Development Environment ──────────────────────────────
# Copy this file to .env and fill in your keys.
# NEVER commit .env to GitHub — it's in .gitignore.

# Your Anthropic API key — get it at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Your Hugging Face token — get it at huggingface.co/settings/tokens
# Free account is fine — just needs read access
HF_TOKEN=hf_...

# ── Google Cloud Text-to-Speech (optional — pre-generates page narration MP3s)
# In GCP: enable "Cloud Text-to-Speech API", create a service account with role
# "Cloud Text-to-Speech User" (roles/cloudtexttospeech.user), create a JSON key.
#
# Local: point to the downloaded key file (requires ffmpeg on PATH for long pages).
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account.json
#
# Alternative local/CI: paste the entire JSON key as a single line (CI uses the
# GOOGLE_SERVICE_ACCOUNT_JSON repository secret the same way).
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
#
# Optional voice (see cloud.google.com/text-to-speech/docs/voices); default in code.
# GOOGLE_TTS_VOICE=en-US-Neural2-F
